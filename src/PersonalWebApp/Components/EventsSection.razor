@using System.Linq

<div class="container">
    <div class="events-header">
        <h2>Events</h2>
        <p>Locked in. There are always others waiting to be announced.</p>
        @if (!IsItAllEvents)
        {
            <div class="period-filter">
                @for (var year = 2015; year <= DateTime.UtcNow.Year; year++)
                {
                    if (Events.All(x => x.Date.Year != year))
                    {
                        <a href="/?period=@year#events" class="period-link" rel="noopener">@year</a>
                    }
                }
                <a href="/?period=all#events" class="period-link" rel="noopener">Show All</a>
            </div>
        }
        else
        {
            <div class="mt-lg">
                <a href="/#events" class="period-link" rel="noopener">Back to current year</a>
            </div>
        }
    </div>

    <div class="events-timeline">
        @foreach (var groupedByYear in Events.GroupBy(x => x.Date.Year).OrderByDescending(x => x.Key))
        {
            <div class="year-group">
                <h3 class="year-label">@groupedByYear.Key</h3>
                @foreach (var entry in groupedByYear.OrderByDescending(x => x.Date).Select((value, i) => new { Index = i, Value = value }))
                {
                    var isUpcoming = DateTime.UtcNow < entry.Value.Date.ToUniversalTime();
                    <div class="event-card">
                        <div class="flex flex--between mb-md">
                            <div>
                                <h4 class="event-title">
                                    @if (string.IsNullOrEmpty(entry.Value.Link))
                                    {
                                        @entry.Value.Title
                                    }
                                    else
                                    {
                                        <a href="@entry.Value.Link" rel="noopener">@entry.Value.Title</a>
                                    }
                                    @if (isUpcoming)
                                    {
                                        <span class="event-badge">Upcoming</span>
                                    }
                                </h4>
                            </div>
                        </div>
                        
                        <div class="event-meta">
                            <div class="event-meta-item">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                @entry.Value.Location
                            </div>
                            <div class="event-meta-item">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                                @entry.Value.Date.ToString("MMM dd, yyyy")
                            </div>
                        </div>
                        
                        <div class="event-items">
                            @foreach (var item in entry.Value.Items)
                            {
                                <div class="event-item">@item.Description</div>
                                if (!isUpcoming && item.Collateral.Any())
                                {
                                    <div class="event-collateral">
                                        @foreach (var collateralItem in item.Collateral.OrderByDescending(x => x.Value))
                                        {
                                            <a href="@collateralItem.Key" class="collateral-chip" rel="noopener">@collateralItem.Value</a>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public EventModel[] Events { get; set; } = [];
    [Parameter] public bool IsItAllEvents { get; set; }
}
